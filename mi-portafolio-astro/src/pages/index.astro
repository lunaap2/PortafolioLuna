---
import { Image } from 'astro:assets';
import '../styles/global.css';
import '../styles/Styles.css';

import faviconImg from '../assets/images/favicon.png';
import profileNavImg from '../assets/images/profile-nav.jpeg';
import profileHeroImg from '../assets/images/profile-hero.jpeg';
import stepfitImg from '../assets/images/stepfit-ecommerce.png';
import goImg from '../assets/images/global-opportunities.png';
import vamsImg from '../assets/images/vams-accesorios.png';
import parkingImg from '../assets/images/flowchart-ai.png';
import toscaImg from '../assets/images/Tosca.png';
---

<!DOCTYPE html>
<html lang="es">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="author" content="Luna Diaz">
    <meta name="description" content="Portafolio de Luna Diaz, experta en Ciencia de Datos y Desarrollo de Software. Descubre mis proyectos de automatización, analítica e ingeniería backend y frontend.">
    
    <meta property="og:title" content="Portafolio Tech - Luna Diaz">
    <meta property="og:description" content="Descubre cómo combino IA, Ciencia de Datos y Desarrollo de Software en soluciones tecnológicas vanguardistas.">
    <meta property="og:image" content="/images/profile-hero.jpeg">
    <meta property="og:type" content="website">

    <title>Portafolio Técnico - Luna Diaz</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet"
        integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
    <link rel="stylesheet" href="https://rsms.me/inter/inter.css" />
    <link rel="icon" type="image/png" href={faviconImg.src} />
</head>

<body class="d-flex flex-column min-vh-100">

    <nav style="background-color: #0f172a; padding: 0.75rem 0;" class="sticky-top shadow-lg">
        <article class="container d-flex align-items-center justify-content-between">

            <article class="d-flex align-items-center gap-4">
                <a href="#" aria-label="Ir al inicio">
                    <Image src={faviconImg} alt="Logotipo Portafolio Luna" style="height: 32px; width: 32px;" width={32} height={32} />
                </a>

                <article class="d-none d-md-flex align-items-center gap-2">
                    <a href="#/inicio" class="nav-link-custom active" data-spa-link>Inicio</a>
                    <a href="#/sobre-mi" class="nav-link-custom" data-spa-link>Sobre Mí</a>
                    <a href="#/proyectos" class="nav-link-custom" data-spa-link>Proyectos</a>
                    <a href="#/habilidades" class="nav-link-custom" data-spa-link>Habilidades</a>
                    <a href="#/certificaciones" class="nav-link-custom" data-spa-link>Certificados</a>
                    <a href="#/testimonios" class="nav-link-custom" data-spa-link>Testimonios</a>
                    <a href="#/contacto" class="nav-link-custom" data-spa-link>Contáctame</a>
                </article>
            </article>

            <article class="d-flex align-items-center gap-3">
                <button class="btn p-0 border-0" style="color: #9ca3af;" aria-label="Abrir menú de navegación">
                    <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path
                            d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9">
                        </path>
                    </svg>
                </button>
                <Image src={profileNavImg} alt="Luna Diaz - Perfil de navegación"
                    class="rounded-circle border border-2"
                    style="height: 35px; width: 35px; object-fit: cover; border-color: #ff69b4 !important;" width={35} height={35} />
            </article>
        </article>
    </nav>

    <article id="particles-container"
        style="position: absolute; width: 100%; height: 600px; z-index: 0; top: 0; left: 0; pointer-events: none; overflow: hidden;">
        <canvas id="canvas-particles" style="background: transparent;"></canvas>
    </article>

    <section id="inicio" class="container py-5" style="position: relative; z-index: 2; background: transparent;">
        <article class="row align-items-center">
            <article class="col-12 col-md-6 text-center text-md-start">
                <h1 class="display-4 text-rosa fw-bold">Luna Díaz</h1>
                <p class="lead">Estudiante de Ciencia de Datos (UNIR) y Auxiliar de Sistemas (CESDE) | Test Automation Engineer Trainee en Globant | BSc en Desarrollo de Software (SENA)</p>
                <p class="badge bg-danger rounded-pill">Disponible para nuevos desafíos</p>
                <br><br>
                <a href="#/proyectos" class="btn btn-rosa btn-lg shadow" data-spa-link
                    style="border: 2px solid #ff1493; border-radius: 30px;">Explorar mi trabajo</a>
            </article>
            
            <article class="col-12 col-md-5 d-flex justify-content-center justify-content-md-end mt-4 mt-md-0">
                <Image src={profileHeroImg}
                    class="img-fluid rounded-circle border border-4 border-rosa shadow-lg"
                    style="width: 300px; height: 300px; object-fit: cover; transition: transform 0.3s ease;" 
                    onmouseover="this.style.transform='scale(1.05)'" 
                    onmouseout="this.style.transform='scale(1)'"
                    alt="Retrato de Luna Diaz, profesional en tecnología" width={300} height={300} loading="eager" />
            </article>
        </article>
    </section>

    <header id="header-alert" class="spa-header" style="position: relative; z-index: 2; background: transparent;">
        <article class="container mt-2">
            <article class="alert alert-danger alert-dismissible fade show d-flex align-items-center p-3 shadow-sm border-0 border-start border-4 border-danger rounded" role="alert" style="background-color: #ffe4ec;">
                <span class="me-2 fs-5"></span>
                <span> Transformando ideas abstractas en soluciones digitales eficientes y escalables.</span>
                <a href="#/contacto" class="alert-link ms-3 text-danger fw-bold text-decoration-underline" data-spa-link>Hablemos sobre tu proyecto</a>
                <button class="btn-close" data-bs-dismiss="alert" aria-label="Cerrar mensaje de bienvenida"></button>
            </article>
        </article>
    </header>

    <section id="sobre-mi" class="container py-5 mt-4">
        <h2 class="text-center text-rosa mb-4 fw-bold">Mi Filosofía Técnica</h2>
        <article class="row">
            <article class="col-12 col-md-4 mb-3">
                <article class="card h-100 border-rosa shadow-sm" style="transition: transform 0.3s; cursor: default;" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">
                    <article class="card-body text-center p-4">
                        <h3 class="card-title text-rosa h4 fw-semibold mb-3">Visión Integral</h3>
                        <p class="card-text text-muted">Desde el pixel en pantalla hasta la infraestructura en servidores. He forjado un perfil técnico híbrido uniendo el ecosistema Backend, el Frontend interactivo y la solidez que exige el Automation QA.</p>
                        <article class="mt-3">
                            <span class="badge bg-info text-dark">Python</span>
                            <span class="badge bg-success">Java</span>
                            <span class="badge bg-warning text-dark">Linux</span>
                        </article>
                    </article>
                </article>
            </article>
            <article class="col-12 col-md-4 mb-3">
                <article class="card h-100 border-rosa shadow-sm" style="transition: transform 0.3s; cursor: default;" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">
                    <article class="card-body text-center p-4">
                        <h3 class="card-title text-rosa h4 fw-semibold mb-3">Soluciones Escalables</h3>
                        <p class="card-text text-muted">Construyo plataformas diseñadas para rendir. Desde interfaces modulares hasta robustas migraciones a la nube, priorizo el código limpio y la arquitectura basada en patrones comprobados de la industria.</p>
                        <article class="mt-3">
                            <span class="badge bg-primary">Full-Stack</span>
                            <span class="badge bg-danger">DB Design</span>
                            <span class="badge bg-dark">Cloud</span>
                        </article>
                    </article>
                </article>
            </article>
            <article class="col-12 col-md-4 mb-3">
                <article class="card h-100 border-rosa shadow-sm" style="transition: transform 0.3s; cursor: default;" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">
                    <article class="card-body text-center p-4">
                        <h3 class="card-title text-rosa h4 fw-semibold mb-3">Aprendizaje Continuo</h3>
                        <p class="card-text text-muted">La tecnología avanza, y mi curiosidad está al mismo ritmo. Busco consolidarme como líder en Machine Learning y en el desarrollo de frameworks automatizados de pruebas que revolucionen la industria corporativa.</p>
                        <article class="mt-3">
                            <span class="badge bg-secondary">Data Science</span>
                            <span class="badge bg-info text-dark">TAE</span>
                            <span class="badge bg-success">Open Source</span>
                        </article>
                    </article>
                </article>
            </article>
        </article>
    </section>

    <section id="proyectos" class="container py-5" style="position: relative; z-index: 2;">
        <article class="text-center mb-5">
            <h2 class="text-center text-rosa mb-4 fw-bold">Casos de Exito</h2>
            <p class="text-muted mt-2">Selección de proyectos destacables combinando IA, lógica de negocio y metodologías ágiles.</p>
        </article>
        
        <article class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">

            <article class="col">
                <article class="card h-100 border-rosa shadow-sm hover-elevate">
                    <img src="https://cdn.pixabay.com/photo/2016/11/19/14/00/code-1839406_1280.jpg" class="card-img-top"
                        alt="Código en pantalla de computadora para LunaTechSpace" style="height: 200px; object-fit: cover;" loading="lazy" />
                    <article class="card-body">
                        <h3 class="card-title text-rosa h5 fw-bold">LunaTechSpace</h3>
                        <p class="card-text">Más que un portafolio, es mi hub digital. Un ecosistema interactivo diseñado para visibilizar y plasmar mi evolución técnica, aptitudes en arquitectura de código y el ADN de mi marca personal.</p>
                        <span class="badge bg-info text-dark">Personal Brand</span>
                        <span class="badge bg-success">Astro + Bootstrap</span>
                    </article>
                    <article class="card-footer bg-transparent border-rosa border-0 pb-3 text-center">
                        <a href="https://github.com/lunaap2/LunaTechSpace" class="btn btn-outline-rosa fw-bold rounded-pill px-4" style="color: #ff1493; border-color: #ff1493;" onmouseover="this.style.backgroundColor='#ff1493'; this.style.color='white'" onmouseout="this.style.backgroundColor='transparent'; this.style.color='#ff1493'" target="_blank" rel="noopener noreferrer">Inspeccionar Repositorio</a>
                    </article>
                </article>
            </article>

            <article class="col">
                <article class="card h-100 border-rosa shadow-sm hover-elevate">
                    <Image src={stepfitImg} class="card-img-top" alt="Captura web de StepFit E-commerce deportivo"
                        style="height: 200px; object-fit: cover;" loading="lazy" />
                    <article class="card-body">
                        <h3 class="card-title text-rosa h5 fw-bold">StepFit Ecommerce</h3>
                        <p class="card-text">Una experiencia de compra ultra fluida y veloz. Plataforma de comercio electrónico deportivo orientada a la conversión, integrando manejo global de carrito, estado de productos e interfaces dinámicas responsivas.</p>
                        <span class="badge bg-primary">E-commerce API</span>
                        <span class="badge bg-warning text-dark">UI/UX</span>
                    </article>
                    <article class="card-footer bg-transparent border-rosa border-0 pb-3 text-center">
                        <a href="https://github.com/Hernanbeltranm/StepFit" class="btn btn-outline-rosa fw-bold rounded-pill px-4" style="color: #ff1493; border-color: #ff1493;" onmouseover="this.style.backgroundColor='#ff1493'; this.style.color='white'" onmouseout="this.style.backgroundColor='transparent'; this.style.color='#ff1493'" target="_blank" rel="noopener noreferrer">Inspeccionar Repositorio</a>
                    </article>
                </article>
            </article>

            <article class="col">
                <article class="card h-100 border-rosa shadow-sm hover-elevate">
                    <Image src={goImg} class="card-img-top"
                        alt="Plataforma GO - Global Opportunities para búsqueda de becas" style="height: 200px; object-fit: cover;" loading="lazy" />
                    <article class="card-body">
                        <h3 class="card-title text-rosa h5 fw-bold">Global Oportunities (GO)</h3>
                        <p class="card-text">Tu pasaporte inteligente al mundo académico. Portal Full-Stack impulsado por conectividad algorítmica y la API de ChatGPT para una traducción en tiempo real con diseño vanguardista desarrollado en Astro.</p>
                        <span class="badge bg-dark text-white">OpenAI Integration</span>
                        <span class="badge bg-danger">Full-Stack Server</span>
                    </article>
                    <article class="card-footer bg-transparent border-rosa border-0 pb-3 text-center">
                        <a href="https://github.com/Hernanbeltranm/GO-Global-Oportunities"
                           class="btn btn-outline-rosa fw-bold rounded-pill px-4" style="color: #ff1493; border-color: #ff1493;" onmouseover="this.style.backgroundColor='#ff1493'; this.style.color='white'" onmouseout="this.style.backgroundColor='transparent'; this.style.color='#ff1493'" target="_blank" rel="noopener noreferrer">Inspeccionar Repositorio</a>
                    </article>
                </article>
            </article>

            <article class="col">
                <article class="card h-100 border-rosa shadow-sm hover-elevate">
                    <Image src={vamsImg} class="card-img-top"
                        alt="Portal del Proyecto Final VAMS Accesorios" style="height: 200px; object-fit: cover;" loading="lazy" />
                    <article class="card-body">
                        <h3 class="card-title text-rosa h5 fw-bold">VAMS Moda & Accesorios</h3>
                        <p class="card-text">Elegancia, consistencia y fiabilidad. Despliegue de panel administrativo online que soporta complejas operaciones de bases de datos mediante CRUD optimizados y listos para su puesta en producción a alta escala.</p>
                        <span class="badge bg-success">Advanced CRUD</span>
                        <span class="badge bg-secondary">Cloud Hosting</span>
                    </article>
                    <article class="card-footer bg-transparent border-rosa border-0 pb-3 text-center">
                        <a href="https://github.com/lunaap2/ProyectoFinal" class="btn btn-outline-rosa fw-bold rounded-pill px-4" style="color: #ff1493; border-color: #ff1493;" onmouseover="this.style.backgroundColor='#ff1493'; this.style.color='white'" onmouseout="this.style.backgroundColor='transparent'; this.style.color='#ff1493'" target="_blank" rel="noopener noreferrer">Inspeccionar Repositorio</a>
                    </article>
                </article>
            </article>

            <article class="col">
                <article class="card h-100 border-rosa shadow-sm hover-elevate">
                    <Image src={parkingImg} class="card-img-top" alt="Diagrama de flujo generado para administración de parqueaderos"
                        style="height: 200px; object-fit: cover;" loading="lazy" />
                    <article class="card-body">
                        <h3 class="card-title text-rosa h5 fw-bold">Parking Logic via AI</h3>
                        <p class="card-text">La lógica algorítmica llevada al límite. Reto estructural donde se prototipó integralmente la mecánica contable y logística de una red de concesionarios y parqueos, asistido estratégicamente por IA para optimización en tiempo record.</p>
                        <span class="badge bg-info text-dark">Data Flow</span>
                        <span class="badge bg-dark text-white">AI Algorithms</span>
                    </article>
                    <article class="card-footer bg-transparent border-rosa border-0 pb-3 text-center">
                        <a href="https://github.com/lunaap2/DiagramaFlujoParking" class="btn btn-outline-rosa fw-bold rounded-pill px-4" style="color: #ff1493; border-color: #ff1493;" onmouseover="this.style.backgroundColor='#ff1493'; this.style.color='white'" onmouseout="this.style.backgroundColor='transparent'; this.style.color='#ff1493'" target="_blank" rel="noopener noreferrer">Inspeccionar Repositorio</a>
                    </article>
                </article>
            </article>

            <article class="col">
                <article class="card h-100 border-rosa shadow-sm hover-elevate">
                    <img src="https://i.revistapym.com.co/old/2021/07/plataformas-de-streaming-en-colombia.jpg?w=920&d=1.25"
                        class="card-img-top" alt="Iconos de apps de streaming en una laptop" style="height: 200px; object-fit: cover;" loading="lazy" />
                    <article class="card-body">
                        <h3 class="card-title text-rosa h5 fw-bold">Platform Streams Java</h3>
                        <p class="card-text">Ingeniería pura encapsulada. Simulación estricta de una plataforma de contenido audiovisual en demanda en Java, demostrando un uso soberbio de Patrones de Programación Orientada a Objetos, Herencia, Polimorfismo y Abstracción.</p>
                        <span class="badge bg-info text-dark">POO Java</span>
                        <span class="badge bg-dark text-white">Systems Design</span>
                    </article>
                    <article class="card-footer bg-transparent border-rosa border-0 pb-3 text-center">
                        <a href="https://github.com/lunaap2/PlataformaStreaming" class="btn btn-outline-rosa fw-bold rounded-pill px-4" style="color: #ff1493; border-color: #ff1493;" onmouseover="this.style.backgroundColor='#ff1493'; this.style.color='white'" onmouseout="this.style.backgroundColor='transparent'; this.style.color='#ff1493'" target="_blank" rel="noopener noreferrer">Inspeccionar Repositorio</a>
                    </article>
                </article>
            </article>

        </article>
    </section>

    <section class="container py-5 mt-3" id="habilidades">
        <h2 class="text-center text-rosa mb-4 fw-bold">Matriz de Habilidades</h2>
        <article class="table-responsive shadow-sm rounded">
            <table class="table table-striped table-hover border-rosa mb-0">
                <thead class="text-white" style="background-color: #ffb6c1;">
                    <tr>
                        <th scope="col" class="py-3 px-4">Tecnología / Herramienta</th>
                        <th scope="col" class="py-3 px-4">Nivel de Dominio</th>
                        <th scope="col" class="py-3 px-4">Track Record</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td class="fw-semibold px-4 pt-3">Test Automation (Tosca / Selenium / QA)</td>
                        <td class="pt-3"><span class="badge bg-success">Intermedio / Crecimiento</span></td>
                        <td class="text-muted pt-3">Implementación constante / Training Globant</td>
                    </tr>
                    <tr>
                        <td class="fw-semibold px-4">SQL, Bases de Datos & BigQuery</td>
                        <td><span class="badge bg-success">Intermedio Sólido</span></td>
                        <td class="text-muted">10+ Modelos de datos y consultas integrales</td>
                    </tr>
                    <tr>
                        <td class="fw-semibold px-4">Lógica Central: Python & Java</td>
                        <td><span class="badge bg-primary">Avanzado</span></td>
                        <td class="text-muted">Desarrollo Backend profundo / IA y POO</td>
                    </tr>
                    <tr>
                        <td class="fw-semibold px-4">DevOps Base: Git, GitHub & CLI Linux</td>
                        <td><span class="badge bg-primary">Avanzado</span></td>
                        <td class="text-muted">Gestión de versiones y despliegues sin fricción</td>
                    </tr>
                    <tr>
                        <td class="fw-semibold px-4">Frontend Moderno: Astro, Tailwind & TS</td>
                        <td><span class="badge bg-primary">Avanzado</span></td>
                        <td class="text-muted">Construcción de interfaces ultrarrápidas y funcionales</td>
                    </tr>
                    <tr>
                        <td class="fw-semibold px-4 pb-3">Infraestructura & Nube (AWS/Azure)</td>
                        <td class="pb-3"><span class="badge bg-warning text-dark">Básico / En progreso</span></td>
                        <td class="text-muted pb-3">Estableciendo los cimientos arquitectónicos Cloud</td>
                    </tr>
                </tbody>
            </table>
        </article>
    </section>

    <section id="certificaciones" class="container py-5 mt-3">
        <h2 class="text-center text-rosa mb-4 fw-bold">Certificaciones</h2>
        <article class="row g-4">
            <!-- Fila 1: Tu núcleo técnico -->
            <article class="col-6 col-md-3">
                <a href="https://academy.tricentis.com/share/gamification/badges/external/f401a2e8-a94f-43a3-85f9-2d9a0a13e6f6?lang=en" target="_blank" rel="noopener noreferrer" class="cert-link text-decoration-none">
                    <article class="card h-100 border-rosa shadow-sm hover-elevate">
                        <article class="card-body text-center d-flex flex-column align-items-center p-3">
                            <div class="d-flex align-items-center justify-content-center mb-3 w-100" style="height: 100px;">
                                <img src="https://cdn.techimply.com/uploads/software/8133/logo/5e978ff0d0963de484f7d05d21cf6c93.png" alt="Tricentis Tosca (AS1)" class="img-fluid cert-img" style="max-height: 100%; max-width: 80%; object-fit: contain;" loading="lazy" />
                            </div>
                            <h3 class="h6 fw-bold mb-0 text-dark mt-auto">Tricentis Tosca<br>(AS1)</h3>
                        </article>
                    </article>
                </a>
            </article>
            <article class="col-6 col-md-3">
                <a href="https://academy.tricentis.com/share/gamification/badges/external/fd4f0486-e1dc-4bcf-a468-24a1b15ef7b0?lang=en" target="_blank" rel="noopener noreferrer" class="cert-link text-decoration-none">
                    <article class="card h-100 border-rosa shadow-sm hover-elevate">
                        <article class="card-body text-center d-flex flex-column align-items-center p-3">
                            <div class="d-flex align-items-center justify-content-center mb-3 w-100" style="height: 100px;">
                                <img src="https://cdn.techimply.com/uploads/software/8133/logo/5e978ff0d0963de484f7d05d21cf6c93.png" alt="Tricentis Tosca (AS2)" class="img-fluid cert-img" style="max-height: 100%; max-width: 80%; object-fit: contain;" loading="lazy" />
                            </div>
                            <h3 class="h6 fw-bold mb-0 text-dark mt-auto">Tricentis Tosca<br>(AS2)</h3>
                        </article>
                    </article>
                </a>
            </article>
            <article class="col-6 col-md-3">
                <a href="https://www.scrumstudy.com/certification/verify?type=SFC&number=1095355" target="_blank" rel="noopener noreferrer" class="cert-link text-decoration-none">
                    <article class="card h-100 border-rosa shadow-sm hover-elevate">
                        <article class="card-body text-center d-flex flex-column align-items-center p-3">
                            <div class="d-flex align-items-center justify-content-center mb-3 w-100" style="height: 100px;">
                                <img src="https://dustinjoosen.nl/img/languages/scrum.png" alt="Scrum Fundamentals" class="img-fluid cert-img" style="max-height: 100%; max-width: 80%; object-fit: contain;" loading="lazy" />
                            </div>
                            <h3 class="h6 fw-bold mb-0 text-dark mt-auto">Scrum Fundamentals</h3>
                        </article>
                    </article>
                </a>
            </article>
            <article class="col-6 col-md-3">
                <a href="https://www.coursera.org/account/accomplishments/verify/FQKQAITG2436" target="_blank" rel="noopener noreferrer" class="cert-link text-decoration-none">

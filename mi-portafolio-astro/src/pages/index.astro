    <script is:inline>
        const canvas = document.getElementById('canvas-particles');
        const ctx = canvas.getContext('2d');
        let particles = [];
        const particleCount = 80;
        let animationFrameId;

        function resizeCanvas() {
            if (!canvas) return;
            canvas.width = window.innerWidth;
            canvas.height = 600;
        }

        window.addEventListener('resize', resizeCanvas);
        resizeCanvas();

        class Particle {
            constructor() {
                this.x = Math.random() * canvas.width;
                this.y = Math.random() * canvas.height;
                this.vx = (Math.random() - 0.5) * 1.5;
                this.vy = (Math.random() - 0.5) * 1.5;
                this.size = Math.random() * 3 + 1;
            }
            update() {
                this.x += this.vx;
                this.y += this.vy;
                if (this.x < 0 || this.x > canvas.width) this.vx *= -1;
                if (this.y < 0 || this.y > canvas.height) this.vy *= -1;
            }
            draw() {
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                ctx.fillStyle = '#ff69b4';
                ctx.fill();
            }
        }

        function init() {
            particles = [];
            for (let i = 0; i < particleCount; i++) {
                particles.push(new Particle());
            }
        }

        function animate() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            particles.forEach(p => {
                p.update();
                p.draw();
            });
            animationFrameId = requestAnimationFrame(animate);
        }

        init();

        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    if (!animationFrameId) animate();
                } else {
                    if (animationFrameId) cancelAnimationFrame(animationFrameId);
                    animationFrameId = null;
                }
            });
        });

        const sectionInicio = document.getElementById('inicio');
        if (sectionInicio) {
            observer.observe(sectionInicio);
        } else {
            animate();
        }
    </script>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- SPA Router Logic -->
    <script is:inline>
        class Router {
            constructor() {
                this.routes = [
                    'inicio', 'sobre-mi', 'proyectos', 
                    'habilidades', 'certificaciones', 'testimonios', 'contacto'
                ];
                
                // Activar el modo SPA
                document.body.classList.add('spa-active');
                
                // Escuchar cambios en el Hash
                window.addEventListener('hashchange', () => this.handleRouting());
                
                // Manejar clic inicial
                this.handleRouting();
            }

            handleRouting() {
                let hash = window.location.hash;
                // Si está vacío o es solo "#", o no tiene la barra de nuestro patrón, default a inicio
                if (!hash || hash === '#' || hash === '#/') {
                    hash = '#/inicio';
                }

                // Extraer el nombre de la sección
                const routeName = hash.replace('#/', '');
                
                // Validar si la ruta existe
                const viewId = this.routes.includes(routeName) ? routeName : 'inicio';
                
                // Renderizar vista
                this.renderView(viewId);
                
                // Actualizar menú
                this.updateActiveNav(viewId);
            }

            renderView(viewId) {
                // Remover clase active de todas las sections y el header
                document.querySelectorAll('section, header.spa-header').forEach(el => {
                    el.classList.remove('active-view');
                });

                // Mostrar la vista que corresponde
                const targetView = document.getElementById(viewId);
                if (targetView) targetView.classList.add('active-view');
                
                // El header de bienvenida solo lo mostraremos en inicio
                if (viewId === 'inicio') {
                    const header = document.getElementById('header-alert');
                    if (header) header.classList.add('active-view');
                }
                
                // Scroll arriba para que siempre inicie arriba al cambiar de vista
                window.scrollTo(0, 0);
            }

            updateActiveNav(viewId) {
                document.querySelectorAll('.nav-link-custom').forEach(link => {
                    link.classList.remove('active');
                    if (link.getAttribute('href') === `#/${viewId}`) {
                        link.classList.add('active');
                    }
                });
            }
        }

        // Inicializar una vez que el DOM esté listo
        document.addEventListener('DOMContentLoaded', () => {
            new Router();
        });
    </script>

